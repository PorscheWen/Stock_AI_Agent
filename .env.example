# LINE Bot 設定
# 請至 https://developers.line.biz/console/ 取得以下資訊

# Channel Secret（Messaging API 頁面 > Channel secret）
CHANNEL_STOCK_SECRET=your_channel_secret_here

# Channel Access Token（Messaging API 頁面 > Channel access token）
CHANNEL_STOCK_ACCESS_TOKEN=your_channel_access_token_here

# 推播目標用戶 ID（在 LINE Bot 傳一則訊息後可從 Webhook 取得，或使用 LINE Developers 的 User ID）
CHANNEL_STOCK_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
